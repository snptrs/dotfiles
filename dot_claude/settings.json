{
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git *)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(jq *)",
      "Bash(command -v *)",
      "Bash(docker compose *)",
      "Read",
      "WebFetch",
      "mcp__val-town__read_file",
      "mcp__val-town__list_files",
      "mcp__val-town__list_vals",
      "mcp__val-town__get_logs",
      "mcp__val-town__get_val_detail",
      "mcp__val-town__get_traces",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__claude-in-chrome__read_network_requests",
      "mcp__claude-in-chrome__read_page"
    ],
    "deny": ["Bash(git push *)"],
    "ask": ["Bash(git commit *)", "Bash(git add *)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs pnpm dlx prettier --write --ignore-unknown || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "advisorModel": "opus",
  "tui": "fullscreen"
}
