{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git *)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(docker compose *)",
      "Read",
      "WebFetch"
    ],
    "deny": [
      "Bash(git commit *)",
      "Bash(git add *)",
      "Bash(git push *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  }
}
