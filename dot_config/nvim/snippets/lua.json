{
  "vim.pack add": {
    "prefix": ["add", "pack"],
    "body": [
      "vim.pack.add {\n\t'https://github.com/$1'\n}\nrequire('$2').setup {$0}"
    ],
    "description": "Add a plugin using vim.pack"
  },
  "set keymap": {
    "prefix": ["keymap"],
    "body": ["vim.keymap.set({ noremap = true, silent = true })"],
    "description": "Set a keymap"
  },
  "diagnostic ignore": {
    "prefix": ["ignore", "diagnostic"],
    "body": ["---@diagnostic disable-next-line: $0"],
    "description": "Ignore a diagnostic"
  }
}
